# Configuration for the ws-v3 hub (packages/relay/src/wsv3-hub.ts).
#
# The hub is a stateless WebSocket multiplexer — no database, no session
# store, no secrets. These are the only variables it reads.

# Port the hub's HTTP + WebSocket server listens on.
POCKET_T_HUB_PORT=4080

# Interface to bind. 0.0.0.0 so a reverse proxy / Fly.io edge can reach it.
POCKET_T_HUB_HOST=0.0.0.0
